[sub_resource type="GDScript" id="GDScript_w24dg"]
script/source = "extends EnemyBase

@onready var animation_player: AnimationPlayer = $AnimationPlayer  # НОВЫЙ УЗЕЛ

func _ready():
	super._ready()
	animation_player.play(\"idle\")

func special_jump_attack():
	# Эффект прыжка
	var tween = create_tween()
	tween.tween_property(self, \"position:y\", position.y - 50, 0.3)
	tween.tween_property(self, \"position:y\", position.y, 0.3)
"

